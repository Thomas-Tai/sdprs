# ============================================================
# SDPRS 環境變數配置模板
# Smart Disaster Prevention Response System
# ============================================================
# 複製此檔案為 .env 並填入實際值
#   本地 LAN:  cp .env.example .env
#   Zeabur:    在 Zeabur 環境變數面板逐項填入（不需要 .env 檔案）
# ============================================================

# ------------------------------------------------------------
# 儀表板認證（保安人員登入）
# ------------------------------------------------------------
DASHBOARD_USER=admin
DASHBOARD_PASS=changeme

# ------------------------------------------------------------
# 邊緣節點認證（Pi → Server API，X-API-Key header）
# ------------------------------------------------------------
EDGE_API_KEY=your-edge-api-key-here

# ------------------------------------------------------------
# Session 加密
# ------------------------------------------------------------
SECRET_KEY=your-secret-key-change-in-production

# ------------------------------------------------------------
# MQTT Broker 配置
# 本地 LAN:  MQTT_BROKER=localhost，MQTT_USE_TLS=false
# Zeabur:    MQTT_BROKER=emqx（Zeabur 內網服務名），MQTT_USE_TLS=false
# ------------------------------------------------------------
MQTT_BROKER=localhost
MQTT_PORT=1883
MQTT_USERNAME=
MQTT_PASSWORD=
MQTT_USE_TLS=false

# ------------------------------------------------------------
# 資料庫配置
# 本地 LAN:  DATABASE_URL 留空，使用 SQLite
# Zeabur:    填入 PostgreSQL 連線串（由 Zeabur PG 服務自動提供）
# ------------------------------------------------------------
DATABASE_URL=
DB_PATH=./data/sdprs.db

# ------------------------------------------------------------
# 媒體保留 & 儲存路徑
# ------------------------------------------------------------
RETENTION_DAYS=30
STORAGE_PATH=./storage

# ------------------------------------------------------------
# 伺服器配置
# Zeabur 會自動注入 $PORT，無需手動設定
# ------------------------------------------------------------
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
