# ============================================================
# SDPRS 環境變數配置模板
# Smart Disaster Prevention Response System
# ============================================================
# 複製此檔案為 .env 並填入實際值
# cp .env.example .env
# ============================================================

# ------------------------------------------------------------
# 儀表板認證（保安人員登入）
# Session-based Login，用於保護儀表板頁面
# ------------------------------------------------------------
# 儀表板登入帳號
DASHBOARD_USER=admin

# 儀表板登入密碼（生產環境請使用強密碼）
DASHBOARD_PASS=changeme

# ------------------------------------------------------------
# 邊緣節點認證（Pi → Server API）
# 邊緣節點透過 X-API-Key HTTP header 傳送
# 適用端點：POST /api/alerts、PUT /api/alerts/{id}/video、POST /api/edge/{node_id}/snapshot
# ------------------------------------------------------------
# 邊緣節點 API 認證金鑰（生產環境請使用隨機生成的金鑰）
EDGE_API_KEY=your-edge-api-key-here

# ------------------------------------------------------------
# Session 加密
# 用於簽名 Session Cookie，保護登入狀態
# ------------------------------------------------------------
# Session Cookie 簽名密鑰（生產環境請使用隨機生成的長字串）
SECRET_KEY=your-secret-key-change-in-production

# ------------------------------------------------------------
# MQTT Broker 配置
# 用於接收邊緣節點的即時事件與串流命令
# ------------------------------------------------------------
# MQTT Broker 地址（預設與中央伺服器同機器）
MQTT_BROKER=localhost

# MQTT Broker 端口
MQTT_PORT=1883

# ------------------------------------------------------------
# 資料庫配置
# SQLite 資料庫路徑（WAL 模式）
# ------------------------------------------------------------
# SQLite 資料庫檔案路徑
DB_PATH=./data/sdprs.db

# ------------------------------------------------------------
# 媒體保留設定
# MP4 錄影檔案的保留天數
# ------------------------------------------------------------
# MP4 保留天數（過期自動刪除）
RETENTION_DAYS=30
# ------------------------------------------------------------
# 儲存路徑配置
# MP4 影片和快照的儲存目錄
# ------------------------------------------------------------
# MP4 影片儲存根目錄
STORAGE_PATH=./storage


# ------------------------------------------------------------
# 伺服器配置
# ------------------------------------------------------------
# 伺服器監聽地址
SERVER_HOST=0.0.0.0

# 伺服器監聽端口
SERVER_PORT=8000
