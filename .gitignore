# ============================================================
# SDPRS .gitignore
# Smart Disaster Prevention Response System
# ============================================================

# ------------------------------------------------------------
# Python
# ------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd
*.egg-info/
dist/
build/
.eggs/
*.egg
*.manifest
*.spec
pip-log.txt
pip-delete-this-directory.txt

# ------------------------------------------------------------
# Virtual Environments
# ------------------------------------------------------------
venv/
.venv/
env/
ENV/
env.bak/
venv.bak/

# ------------------------------------------------------------
# IDE / Editors
# ------------------------------------------------------------
# VSCode (keep settings.json if needed)
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json

# PyCharm / IntelliJ
.idea/

# Vim
*.swp
*.swo
*~

# macOS
.DS_Store
.AppleDouble
.LSOverride

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini

# ------------------------------------------------------------
# Environment Variables & Secrets
# ------------------------------------------------------------
.env
.env.local
.env.*.local
!.env.example
*.pem
*.key
secrets/

# ------------------------------------------------------------
# Runtime Data (generated by system)
# ------------------------------------------------------------
# Edge node local storage
events/
storage/
data/

# SQLite database
*.db
*.db-wal
*.db-shm
*.sqlite
*.sqlite3

# ------------------------------------------------------------
# Media & Logs (auto-generated)
# ------------------------------------------------------------
*.mp4
*.avi
*.mov
*.mkv
*.log
logs/

# Temporary files
tmp/
temp/
*.tmp
*.temp
*.bak

# ------------------------------------------------------------
# Node.js (if frontend build)
# ------------------------------------------------------------
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Build output
.output/
.cache/

# ------------------------------------------------------------
# Docker
# ------------------------------------------------------------
.docker/

# ------------------------------------------------------------
# System
# ------------------------------------------------------------
*.pid
*.seed
*.pid.lock

# Coverage reports
htmlcov/
.tox/
.nox/
.coverage
.coverage.*
.cache
nosetests.xml
coverage.xml
*.cover
*.py,cover
.hypothesis/
.pytest_cache/
pytestdebug.log

# mypy
.mypy_cache/
.dmypy.json
dmypy.json

# Pyre
.pyre/

# ------------------------------------------------------------
# Project-specific ignores
# ------------------------------------------------------------
# Local configuration overrides
config.local.yaml
config.local.json
config.local.py

# Backup files
*.backup
*.old