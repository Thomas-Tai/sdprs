# ============================================================
# SDPRS Central Server — Environment Variables Template
# ============================================================
# 使用方式（本地）：
#   cp .env.example .env  ; 編輯 .env 填入實際值
#
# 使用方式（Zeabur）：
#   在服務 Variables 頁面逐項貼入。同樣分為「必填 4 個」與「進階」。
#
# 生成隨機密鑰：
#   python3 -c "import secrets; print(secrets.token_hex(32))"
# ============================================================

# ── 必填（缺一即 pydantic ValidationError 導致 crash）─────────
DASHBOARD_USER=admin
DASHBOARD_PASS=change-me-dashboard-password
EDGE_API_KEY=change-me-edge-api-key
SECRET_KEY=change-me-64-hex-chars-from-secrets-token-hex-32

# ── MQTT（可選；MVP 純玻璃偵測可全部留空）─────────────────────
# 雲端：填 EMQX private hostname（如 sdprs-xxx.zeabur.internal）
# LAN ：填中央伺服器 IP 或 localhost
#MQTT_BROKER=localhost
#MQTT_PORT=1883
#MQTT_USERNAME=sdprs
#MQTT_PASSWORD=
#MQTT_USE_TLS=false

# ── 資料庫（可選；空值 = SQLite WAL）─────────────────────────
# 若用 PostgreSQL（Zeabur Marketplace）：
#DATABASE_URL=postgresql://${POSTGRESQL_USERNAME}:${POSTGRESQL_PASSWORD}@${POSTGRESQL_HOST}:${POSTGRESQL_PORT}/${POSTGRESQL_DATABASE}
#DB_PATH=./data/sdprs.db

# ── 儲存與保留（可選）────────────────────────────────────────
#RETENTION_DAYS=30
#STORAGE_PATH=./storage

# ── 伺服器綁定（一般不需動）──────────────────────────────────
#SERVER_HOST=0.0.0.0
#SERVER_PORT=8000
