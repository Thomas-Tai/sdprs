# Auto-detect text files and normalize line endings
* text=auto

# Force LF for shell scripts (deployed to Linux Pi/Zeabur)
*.sh text eol=lf
*.py text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.json text eol=lf
*.md text eol=lf
*.conf text eol=lf
*.service text eol=lf
*.html text eol=lf
*.css text eol=lf
*.js text eol=lf

# Windows-only files keep CRLF
*.bat text eol=crlf
*.cmd text eol=crlf
